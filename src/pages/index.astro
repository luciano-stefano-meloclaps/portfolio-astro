---
// src/pages/index.astro
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/sections/Hero.astro';
import About from '@/components/sections/About.astro';
import Projects from '@/components/sections/Projects.astro';
import Career from '@/components/sections/Career.astro';
import Certifications from '@/components/sections/Certifications.astro';
import Contact from '@/components/sections/Contact.astro';
import Footer from '@/components/sections/Footer.astro';
---

<Layout
  preloadImages={[
    '/assets/images/hero/hero10.jpg',
    /* additional resources (e.g., first project) can be added later */
  ]}
>
  <main>
    <Hero />
    <About />
    <Projects />
    <Career />
    <Certifications />
    <Contact />
    <Footer />
  </main>
</Layout>
