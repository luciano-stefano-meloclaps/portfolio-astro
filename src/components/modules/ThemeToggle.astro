---
// src/components/modules/ThemeToggle.astro
// VERSIÓN "CONTROL PURO" MULTI-INSTANCIA: Soporta múltiples botones en una misma página.
const { class: className, ...rest } = Astro.props;
---

<button
  class:list={[
    'js-theme-toggle text-text-navbar/50 hover:text-text-navbar relative flex h-8 w-8 items-center justify-center rounded-full transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-text-primary dark:text-text-primary/50 hover:dark:text-text-primary',
    className,
  ]}
  aria-label="Toggle light and dark theme"
  {...rest}
>
  <div class="relative h-5 w-5 overflow-hidden pointer-events-none">
    <div
      class="js-icon-sun absolute inset-0 fill-none stroke-current"
      style="stroke-width: 2.0; stroke-linecap: round;"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24">
        <circle class="js-sun-core" cx="12" cy="12" r="4"></circle>
        <g class="js-sun-rays">
          <line x1="12" y1="1" x2="12" y2="3"></line><line
            x1="12"
            y1="21"
            x2="12"
            y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"
          ></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line
            x1="1"
            y1="12"
            x2="3"
            y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line
            x1="4.22"
            y1="19.78"
            x2="5.64"
            y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"
          ></line>
        </g>
      </svg>
    </div>
    <div
      class="js-icon-moon absolute inset-0 fill-none stroke-current opacity-0"
      style="stroke-width: 2.0; stroke-linecap: round; stroke-linejoin: round;"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </div>
  </div>
</button>

<script>
  import gsap from 'gsap';

  function initThemeToggles() {
    const toggles = document.querySelectorAll('.js-theme-toggle');
    const isDarkMode = document.documentElement.classList.contains('dark');
    
    // Array para rastrear todas las animaciones activas en la página actual
    const activeTimelines: gsap.core.Timeline[] = [];

    toggles.forEach((toggle) => {
      // Evitar doble inicialización
      if (toggle.hasAttribute('data-initialized')) return;
      toggle.setAttribute('data-initialized', 'true');

      const sunRays = toggle.querySelector('.js-sun-rays');
      const sunCore = toggle.querySelector('.js-sun-core');
      const moonIcon = toggle.querySelector('.js-icon-moon');

      // Animación única y centralizada
      const sunToMoon = gsap.timeline({
        paused: true,
        defaults: { duration: 0.4, ease: 'power2.inOut' },
      });
      
      sunToMoon
        .to(sunRays, { scale: 0, autoAlpha: 0, transformOrigin: 'center center' })
        .to(moonIcon, { y: 0, autoAlpha: 1 }, '<')
        .to(sunCore, { autoAlpha: 0 }, '<0.1');

      // ⚡ CRITICAL FIX: Sincronización del estado inicial de la línea de tiempo.
      if (isDarkMode) {
        sunToMoon.progress(1); // Mueve la animación al final (Estado Luna)
      } else {
        sunToMoon.progress(0); // Mueve la animación al inicio (Estado Sol)
      }

      // Añadimos la línea de tiempo a la colección global
      activeTimelines.push(sunToMoon);

      toggle.addEventListener('click', () => {
        const currentlyDark = document.documentElement.classList.contains('dark');
        const nextDark = !currentlyDark;

        // Cambiar clase en HTML (afecta a todos)
        if (nextDark) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        
        localStorage.setItem('theme', nextDark ? 'dark' : 'light');

        // Disparar evento para sincronizar OTRAS instancias
        document.dispatchEvent(new CustomEvent('theme-changed', { detail: { isDark: nextDark } }));
      });
    });

    // ⚡ TECH DEBT FIX: Listener Global ÚNICO.
    // Solo registramos el listener si no fue registrado previamente en el document.
    // Esto previene que se apilen 10 listeners al navegar por 10 páginas (SPA mode).
    if (!(document as any).hasThemeSyncListener) {
      (document as any).hasThemeSyncListener = true;
      
      document.addEventListener('theme-changed', (e: any) => {
        const { isDark } = e.detail;
        
        // Disparamos play o reverse en TODAS las instancias capturadas
        activeTimelines.forEach((tl) => {
          if (isDark) tl.play();
          else tl.reverse();
        });
      });
    }
  }

  // Ejecutar en cada carga de página (soporta View Transitions)
  document.addEventListener('astro:page-load', initThemeToggles);
  document.addEventListener('DOMContentLoaded', initThemeToggles);
</script>

