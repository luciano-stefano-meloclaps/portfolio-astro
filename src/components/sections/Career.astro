---
// src/components/sections/Career.astro
import { getCollection, type CollectionEntry } from 'astro:content';
import ExperienceCard from '@/components/modules/ExperienceCard.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import Button from '@/components/ui/Button.astro';
import { IconChevronDown } from '@tabler/icons-react';

const allCareerItems: CollectionEntry<'career'>[] = await getCollection('career');

// Relevance order requested by the user
const relevanceOrder = [
  'Co-Líder de Proyectos Web',
  'Tecnicatura Universitaria en Programación',
  'Tecnicatura Universitaria en Inteligencia Artificial',
  'Carrera de Desarrollo Frontend & Diseño UX/UI'
];

const getRelevance = (title: string) => {
  const index = relevanceOrder.indexOf(title);
  return index !== -1 ? index : 99;
};

allCareerItems.sort(
  (a, b) => getRelevance(a.data.title) - getRelevance(b.data.title)
);

const INITIAL_LIMIT = 2;
---

<section id="career" class="pt-40 md:pt-48 pb-24 md:pb-32 relative">
  <div class="container-narrow career-section-content space-y-20">
    
    <div class="flex w-full flex-col items-center justify-center">
      <SectionTitle
        title="TRAYECTORIA"
        subtitle="El camino recorrido: formación, trabajos y evolución profesional."
        class="items-center text-center"
      />
    </div>

    <!-- SORT CONTROLS -->
    <div class="flex justify-center -mt-8 mb-4">
      <div class="sort-control-container p-[1px] bg-border/20 shadow-base overflow-hidden octagonal-shape">
        <div class="inline-flex glass-panel p-1 sort-control-inner relative overflow-hidden octagonal-shape">
          
          <!-- Slider Background -->
          <div 
            id="sort-slider" 
            class="absolute top-1 bottom-1 left-1 bg-text-primary pointer-events-none z-0 octagonal-shape"
          ></div>

          <button 
            id="sort-chrono" 
            data-sort="chrono"
            class="sort-button px-6 py-2 text-xs md:text-sm font-medium transition-colors duration-500 text-text-secondary z-10 relative octagonal-shape"
          >
            Cronológico
          </button>
          <button 
            id="sort-relevance" 
            data-sort="relevance"
            class="sort-button active px-6 py-2 text-xs md:text-sm font-medium transition-colors duration-500 text-background z-10 relative octagonal-shape"
          >
            Relevancia
          </button>
        </div>
      </div>
    </div>

    <div class="relative">
      <div
        class="timeline-line absolute left-[19px] md:left-6 top-4 bottom-0 w-0.5 -translate-x-1/2 bg-border opacity-60"
      >
      </div>

      <div id="timeline-container" class="space-y-12">
        {
          allCareerItems.map((item, index) => {
            const isHidden = index >= INITIAL_LIMIT;
            return (
              <div 
                class={`timeline-item flex gap-6 md:gap-10 ${isHidden ? 'hidden' : ''}`}
                data-date={item.data.startDate.valueOf()}
                data-relevance={getRelevance(item.data.title)}
              >
                
                <!-- COLUMNA IZQUIERDA (Línea y Punto) -->
                <div class="relative flex flex-col items-center w-10 md:w-12 shrink-0">
                  <div class="relative z-10 top-8 w-4 h-4 rounded-full bg-background border-2 border-text-primary shadow-[0_0_10px_rgba(0,0,0,0.2)]"></div>
                </div>

                <!-- COLUMNA DERECHA (Tarjeta) -->
                <div class="flex-1 pb-8">
                  <ExperienceCard experience={item} />
                </div>
                
              </div>
            );
          })
        }
      </div>
    </div>

    <!-- VER MAS BUTTON -->
    {
      allCareerItems.length > INITIAL_LIMIT && (
        <div class="mt-12 flex justify-center" id="career-load-more-container">
          <Button id="career-load-more-btn" variant="secondary" class="group min-w-[200px]">
            Ver Más Trayectoria
            <IconChevronDown className="w-4 h-4 transition-transform duration-300 group-hover:translate-y-1" />
          </Button>
        </div>
      )
    }
  </div>
</section>

<style>
  .octagonal-shape {
    clip-path: polygon(
      10px 0, 
      calc(100% - 10px) 0, 
      100% 10px, 
      100% calc(100% - 10px), 
      calc(100% - 10px) 100%, 
      10px 100%, 
      0 calc(100% - 10px), 
      0 10px
    );
  }

  .sort-control-inner {
    background-color: rgb(var(--color-panel-bg) / 0.15);
    backdrop-filter: blur(var(--blur-base));
  }

  .sort-button.active {
    cursor: default;
  }
  .sort-button:not(.active):hover {
    color: rgb(var(--color-text-primary));
    background-color: rgb(var(--color-text-primary) / 0.1);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initCareer() {
    const section = document.querySelector('.career-section-content');
    if (!section) return;

    const line = section.querySelector('.timeline-line');
    const container = document.getElementById('timeline-container');
    const sortButtons = document.querySelectorAll('.sort-button');
    const slider = document.getElementById('sort-slider');
    const loadMoreBtn = document.getElementById('career-load-more-btn');
    const loadMoreContainer = document.getElementById('career-load-more-container');
    
    // Convert NodeList to Array and cast
    let allItems = gsap.utils.toArray('.timeline-item') as HTMLElement[];
    let visibleCount = 2; // INITIAL_LIMIT

    // Utility to apply visibility based on current sorted array
    const applyVisibility = (animateItemsIn = false) => {
      const currentItemsInDom = gsap.utils.toArray('.timeline-item') as HTMLElement[];
      const itemsToAnimate: HTMLElement[] = [];

      currentItemsInDom.forEach((item, index) => {
        if (index < visibleCount) {
          if (item.classList.contains('hidden')) {
            item.classList.remove('hidden');
            itemsToAnimate.push(item);
          }
        } else {
          item.classList.add('hidden');
        }
      });

      if (animateItemsIn && itemsToAnimate.length > 0) {
        gsap.fromTo(itemsToAnimate, 
          { autoAlpha: 0, y: 20 },
          { autoAlpha: 1, y: 0, stagger: 0.1, duration: 0.5, ease: 'power2.out' }
        );
      }

      // Update button visibility
      if (loadMoreContainer) {
        if (visibleCount >= currentItemsInDom.length) {
          loadMoreContainer.style.display = 'none';
        } else {
          loadMoreContainer.style.display = 'flex';
        }
      }
    };

    // Load More click
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', () => {
        visibleCount += 2;
        applyVisibility(true);
        ScrollTrigger.refresh();
      });
    }

    // -- INITIAL ANIMATION --
    const initialVisible = allItems.filter(item => !item.classList.contains('hidden'));
    gsap.set(line, { scaleY: 0, transformOrigin: "top center" });
    gsap.set(initialVisible, { autoAlpha: 0, x: -20 });

    const updateSlider = (activeBtn: HTMLElement, animate = true) => {
      if (!slider) return;
      const rect = activeBtn.getBoundingClientRect();
      const parentRect = activeBtn.parentElement!.getBoundingClientRect();
      
      const left = rect.left - parentRect.left;
      const width = rect.width;

      if (animate) {
        gsap.to(slider, { left: left, width: width, duration: 0.5, ease: 'power3.inOut' });
      } else {
        gsap.set(slider, { left: left, width: width });
      }
    };

    const activeBtn = document.querySelector('.sort-button.active') as HTMLElement;
    if (activeBtn) updateSlider(activeBtn, false);

    const entranceTl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        toggleActions: 'play none none reverse'
      },
    });

    entranceTl.to(line, {
      scaleY: 1,
      duration: 1.5,
      ease: 'power2.inOut',
    })
    .to(
      initialVisible,
      { autoAlpha: 1, x: 0, stagger: 0.15, duration: 0.6, ease: 'power2.out' },
      '-=1.2'
    );

    // -- SORTING LOGIC --
    sortButtons.forEach(button => {
      button.addEventListener('click', () => {
        if (button.classList.contains('active')) return;

        const sortType = (button as HTMLElement).dataset.sort;
        
        sortButtons.forEach(btn => {
          btn.classList.remove('active', 'text-background');
          btn.classList.add('text-text-secondary');
        });
        button.classList.add('active', 'text-background');
        button.classList.remove('text-text-secondary');

        updateSlider(button as HTMLElement);

        // Get currently visible items
        const currentItemsInDom = gsap.utils.toArray('.timeline-item') as HTMLElement[];
        const visibleItems = currentItemsInDom.filter(i => !i.classList.contains('hidden'));

        gsap.to(visibleItems, {
          autoAlpha: 0,
          y: 5,
          stagger: 0.04,
          duration: 0.3,
          ease: 'power2.in',
          onComplete: () => {
            // Sort
            const sortedItems = [...currentItemsInDom].sort((a, b) => {
              if (sortType === 'chrono') {
                return Number(b.dataset.date) - Number(a.dataset.date);
              } else {
                return Number(a.dataset.relevance) - Number(b.dataset.relevance);
              }
            });

            // Re-append
            sortedItems.forEach(item => container?.appendChild(item));
            
            // Re-apply classes so only the first `visibleCount` are shown
            let newlyVisible: HTMLElement[] = [];
            sortedItems.forEach((item, index) => {
              if (index < visibleCount) {
                item.classList.remove('hidden');
                newlyVisible.push(item);
              } else {
                item.classList.add('hidden');
              }
            });

            // Animate In NEWLY VISIBLE items
            gsap.fromTo(newlyVisible, 
              { autoAlpha: 0, y: -5 },
              { autoAlpha: 1, y: 0, stagger: 0.08, duration: 0.4, ease: 'power2.out', onComplete: () => ScrollTrigger.refresh() }
            );
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initCareer);
  document.addEventListener('DOMContentLoaded', initCareer);
</script>