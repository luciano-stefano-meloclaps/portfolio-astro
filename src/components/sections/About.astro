---
// src/components/sections/About.astro
import Card from '@/components/ui/Card.astro';
import TerminalHeader from '@/components/modules/TerminalHeader.astro';
import StatCard from '@/components/ui/StatCard.astro';
import TechChip from '@/components/ui/TechChip.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import { techIconMap } from '@/config/tech-icon-map';

import { IconPackages, IconSitemap, IconBrain } from '@tabler/icons-react';
---

<section id="about" class="py-24 md:py-32">
  <div class="container-narrow about-section-content space-y-8">
    <SectionTitle
      title="Sobre Mí"
      subtitle="Cómo pienso, cómo trabajo y un poco más sobre quién soy."
    />

    <Card padding="none" class="overflow-hidden">
      <TerminalHeader />
    </Card>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <Card class="md:col-span-2">
        <h2 class="text-h3 font-bold text-text-primary">Perfil</h2>
        <div
          class="prose prose-invert mt-6 max-w-none space-y-4 text-text-secondary"
          style="font-weight: 300;"
        >
          <p>
            Técnico Universitario en Programación y Desarrollador Fullstack. Mi
            enfoque se centra en el desarrollo de <strong
              >SPAs (Single Page Applications)</strong
            >
            escalables, fusionando la robustez del backend en <strong
              >.NET</strong
            > bajo patrones de <strong>Clean Architecture</strong> con una ingeniería
            de frontend performante en <strong>React</strong>.
          </p>
          <p>
            Especialista en lógica de componentes reutilizables y sistemas de
            diseño. Potencio el ciclo de desarrollo integrando herramientas de <strong
              >IA</strong
            > para la optimización de algoritmos y la entrega de soluciones de software
            eficientes y mantenibles.
          </p>
        </div>
      </Card>

      <div class="space-y-8">
        <StatCard value="10+" label="Proyectos de todo tipo" />
        <StatCard value="3+" label="Años Programando" />
      </div>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      <Card>
        <div class="flex items-center gap-x-4 text-xl">
          <IconPackages
            className="icon-base text-text-secondary"
            strokeWidth={1.0}
          />
          <h3 class="text-lg font-bold text-text-primary">
            Arquitectura Backend
          </h3>
        </div>
        <p class="mt-4 text-sm text-text-secondary" style="font-weight: 300;">
          Desarrollo de APIs RESTful escalables aplicando Clean Architecture.
          Manejo de datos con Entity Framework Core y MySQL, asegurando la
          protección mediante Token JWT.
        </p>
      </Card>
      <Card>
        <div class="flex items-center gap-x-4 text-xl">
          <IconSitemap
            className="icon-base text-text-secondary"
            strokeWidth={1.0}
          />
          <h3 class="text-lg font-bold text-text-primary">
            Ingeniería Frontend
          </h3>
        </div>
        <p class="mt-4 text-sm text-text-secondary" style="font-weight: 300;">
          Traducción fiel de diseños de Figma a interfaces modernas en React,
          JavaScript y TypeScript. Implementación ágil de estilos utilizando
          frameworks como TailwindCSS y Bootstrap.
        </p>
      </Card>
      <Card>
        <div class="flex items-center gap-x-4 text-xl">
          <IconBrain
            className="icon-base text-text-secondary"
            strokeWidth={1.0}
          />
          <h3 class="text-lg font-bold text-text-primary">
            Inteligencia Artificial
          </h3>
        </div>
        <p class="mt-4 text-sm text-text-secondary" style="font-weight: 300;">
          Potenciación del flujo de desarrollo mediante la integración de LLMs y
          Agentes. Respaldo académico activo a través de la Tecnicatura en
          Inteligencia Artificial y varios cursos.
        </p>
      </Card>
    </div>

    <!-- PANEL DE TOOLKIT (SISTEMA ORBIT) -->
    <Card class="relative overflow-hidden">
      <h3
        class="text-center font-sans text-xs uppercase tracking-[0.3em] text-text-secondary/60"
      >
        Toolkit Principal
      </h3>

      <div class="orbit-container mt-12 pb-6">
        <!-- Row 1: Logic & Core (LTR) -->
        <div class="orbit-wrapper" data-speed="1.1">
          <div class="orbit-track track-ltr">
            {[...Array(2)].map(() => (
              <div class="orbit-group">
                <TechChip Icon={techIconMap['.net']} name=".NET" />
                <TechChip Icon={techIconMap['c#']} name="C#" />
                <TechChip Icon={techIconMap['python']} name="Python" />
                <TechChip Icon={techIconMap['typescript']} name="TypeScript" />
                <TechChip Icon={techIconMap['sql']} name="SQL" />
                <TechChip Icon={techIconMap['javascript']} name="Javascript" />
              </div>
            ))}
          </div>
        </div>

        <!-- Row 2: Frontend & Styling (RTL) -->
        <div class="orbit-wrapper mt-4" data-speed="0.85">
          <div class="orbit-track track-rtl">
            {[...Array(2)].map(() => (
              <div class="orbit-group">
                <TechChip Icon={techIconMap['react']} name="React" />
                <TechChip Icon={techIconMap['astro']} name="Astro" />
                <TechChip Icon={techIconMap['tailwind']} name="Tailwind" />
                <TechChip Icon={techIconMap['bootstrap']} name="Bootstrap" />
                <TechChip Icon={techIconMap['sass']} name="Sass" />
                <TechChip Icon={techIconMap['vite']} name="Vite" />
              </div>
            ))}
          </div>
        </div>

        <!-- Row 3: Tools & Ops (LTR) -->
        <div class="orbit-wrapper mt-4" data-speed="1.0">
          <div class="orbit-track track-ltr">
            {[...Array(2)].map(() => (
              <div class="orbit-group">
                <TechChip Icon={techIconMap['figma']} name="Figma" />
                <TechChip Icon={techIconMap['github']} name="GitHub" />
                <TechChip Icon={techIconMap['docker']} name="Docker" />
                <TechChip Icon={techIconMap['seo']} name="SEO" />
                <TechChip Icon={techIconMap['git']} name="Git" />
                <TechChip Icon={techIconMap['trello']} name="Trello" />
              </div>
            ))}
          </div>
        </div>
      </div>
    </Card>
  </div>
</section>

<script>
  import gsap from 'gsap';

  /**
   * SEAMLESS HORIZONTAL LOOP HELPER
   * Logic: Usamos dos grupos idénticos sin gap entre ellos en el contenedor padre.
   * El gap se maneja internamente en el grupo mediante padding-right.
   * De esta forma, el punto de reset (-50%) es matemáticamente idéntico al inicio (0%).
   */
  function initOrbit() {
    const wrappers = document.querySelectorAll('.orbit-wrapper');
    const container = document.querySelector('.orbit-container');
    
    if (!container) return;

    wrappers.forEach((wrapper) => {
      const track = wrapper.querySelector('.orbit-track') as HTMLElement;
      if (!track) return;

      const speed = parseFloat(wrapper.getAttribute('data-speed') || '1');
      const isRTL = track.classList.contains('track-rtl');
      
      // Configuramos el estado inicial limpio
      gsap.set(track, { x: 0, xPercent: 0 });

      const xTarget = isRTL ? -50 : 0;
      const xStart = isRTL ? 0 : -50;
      
      // Animación de loop continuo
      const horizontalTween = gsap.fromTo(track, 
        { xPercent: xStart },
        { 
          xPercent: xTarget, 
          duration: 40 / speed, 
          ease: "none", 
          repeat: -1,
          // Forzar renderizado para evitar jumps por rounding del navegador
          force3D: true
        }
      );

      // Efecto "Floating" ultra sutil e independiente
      const items = track.querySelectorAll('.orbit-group > *');
      items.forEach((item, index) => {
        gsap.to(item, {
          y: "random(-2, 2)",
          duration: "random(3, 5)",
          repeat: -1,
          yoyo: true,
          ease: "sine.inOut",
          delay: index * 0.2
        });
      });

      // Control interactivo de velocidad (Braking)
      wrapper.addEventListener('mouseenter', () => {
        gsap.to(horizontalTween, { timeScale: 0.15, duration: 1.2, ease: "power3.out" });
      });

      wrapper.addEventListener('mouseleave', () => {
        gsap.to(horizontalTween, { timeScale: 1, duration: 1.5, ease: "power3.inOut" });
      });

      // Manejo sofisticado de hover por chip
      items.forEach(item => {
        item.addEventListener('mouseenter', () => {
          gsap.to(item, { 
            scale: 1.05, 
            zIndex: 10,
            duration: 0.4, 
            ease: "power3.out",
            overwrite: "auto"
          });
        });
        item.addEventListener('mouseleave', () => {
          gsap.to(item, { 
            scale: 1, 
            zIndex: 1, 
            duration: 0.5, 
            ease: "power3.inOut",
            overwrite: "auto"
          });
        });
      });
    });
  }

  // Asegurar reinicio en navegaciones de Astro
  document.addEventListener('astro:page-load', initOrbit);
  // Inicialización inmediata
  initOrbit();
</script>

<style>
  .orbit-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    /* Mascaras de precisión para fades suaves */
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .orbit-wrapper {
    display: flex;
    overflow: hidden;
    user-select: none;
  }

  .orbit-track {
    display: flex;
    flex-shrink: 0;
    /* CRÍTICO: Gap 0 para que los grupos se toquen exactamente */
    gap: 0;
    padding: 0.75rem 0;
    width: max-content;
    will-change: transform;
  }

  .orbit-group {
    display: flex;
    flex-shrink: 0;
    gap: 1.5rem;
    align-items: center;
    /* CRÍTICO: El padding-right debe ser IDENTICO al gap para que el loop sea perfecto */
    padding-right: 1.5rem;
  }

  /* Efecto de foco sutil */
  .orbit-container:hover .orbit-wrapper:not(:hover) {
    opacity: 0.7;
    filter: saturate(0.8);
  }

  @media (max-width: 768px) {
    .orbit-container {
      mask-image: linear-gradient(
        to right,
        transparent,
        black 5%,
        black 95%,
        transparent
      );
    }
  }
</style>
