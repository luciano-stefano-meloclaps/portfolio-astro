---
// src/components/ui/StatusBadge.astro
import {
  IconCircleCheckFilled, // Icono más sólido y premium
  IconTool,
  IconArchiveFilled,
  IconAlertCircleFilled,
  IconSeo,
} from '@tabler/icons-react';

// Definimos los estados posibles
type Status = 'Completed' | 'In Progress' | 'Archived' | 'On Hold';

interface Props {
  status: string;
  class?: string;
}

const { status, class: className } = Astro.props;

// Configuración de Diseño Centralizada
const statusConfig: Record<
  string,
  { icon: any; colorClass: string; label: string }
> = {
  Completed: {
    icon: IconCircleCheckFilled,
    // Verde esmeralda vibrante con fondo sutil
    colorClass:
      'text-emerald-400 bg-emerald-500/10 border-emerald-500/20 shadow-[0_0_10px_rgba(52,211,153,0.1)]',
    label: 'Completado',
  },
  'In Progress': {
    icon: IconTool,
    colorClass: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
    label: 'Desarrollando',
  },
  Archived: {
    icon: IconArchiveFilled,
    colorClass: 'text-sky-400 bg-sky-500/10 border-sky-500/20 shadow-[0_0_10px_rgba(56,189,248,0.1)]',
    label: 'Archivado',
  },
  default: {
    icon: IconAlertCircleFilled,
    colorClass: 'text-gray-400 bg-gray-500/10 border-gray-500/20',
    label: status,
  },
  SEO: {
    icon: IconSeo,
    // Mint (#A8E8D8 = rgb(168, 232, 216)) con glow sutil
    colorClass:
      'border-[#A8E8D8]/30 bg-[#A8E8D8]/10 text-[#A8E8D8] shadow-[0_0_10px_rgba(168,232,216,0.12)]',
    label: 'SEO',
  },
};

const config = statusConfig[status] || statusConfig['default'];
const Icon = config.icon;
---

<div
  class:list={[
    'inline-flex cursor-default items-center justify-center gap-x-1.5 rounded-small border px-3 py-1 min-w-[130px] w-fit backdrop-blur-md transition-all duration-300 hover:scale-105',
    config.colorClass,
    className,
  ]}
>
  <Icon
    className="h-4 w-4 shrink-0 flex-none"
  />

  <span
    class="pt-[1px] text-[10px] font-bold uppercase leading-none tracking-wider"
  >
    {config.label}
  </span>
</div>
