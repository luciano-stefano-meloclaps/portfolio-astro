---
// src/components/ui/StatusChip.astro
import type { ElementType } from 'react';

// Definimos los estados posibles (Ampliados)
type Variant =
  | 'positive' // Verde (Éxito)
  | 'warning' // Ambar (Atención)
  | 'neutral' // Gris (Inactivo)
  | 'active' // Cyan (En curso)
  | 'info' // Azul (Información)
  | 'purple' // Violeta (.NET/C#)
  | 'indigo' // Indigo (Educación/Académico)
  | 'rose'; // Rosa (Freelance/Creativo)

interface Props {
  Icon: ElementType | any;
  label: string;
  value: string;
  variant?: Variant;
  surface?: 'default' | 'glass' | 'solid';
  class?: string;
}

const {
  Icon,
  label,
  value,
  variant = 'positive',
  surface = 'default',
  class: className,
} = Astro.props;

const surfaceConfig: Record<'default' | 'glass' | 'solid', string> = {
  default: 'bg-panel/20 dark:bg-panel/10 border-border backdrop-blur-[var(--blur-base)]',
  glass: 'bg-background/80 border-white/10 backdrop-blur-xl shadow-[0_4px_12px_rgba(0,0,0,0.5)]',
  solid: 'bg-panel border-border',
};

const variantConfig: Record<
  Variant,
  { text: string; dot: string; glow: string }
> = {
  positive: {
    text: 'text-emerald-500',
    dot: 'bg-emerald-500',
    glow: 'shadow-emerald-500/20',
  },
  warning: {
    text: 'text-amber-500',
    dot: 'bg-amber-500',
    glow: 'shadow-amber-500/20',
  },
  neutral: {
    text: 'text-slate-400',
    dot: 'bg-slate-500',
    glow: 'shadow-slate-500/20',
  },
  active: {
    text: 'text-cyan-400',
    dot: 'bg-cyan-500',
    glow: 'shadow-cyan-500/20',
  },
  info: {
    text: 'text-blue-400',
    dot: 'bg-blue-500',
    glow: 'shadow-blue-500/20',
  },
  purple: {
    text: 'text-purple-400',
    dot: 'bg-purple-500',
    glow: 'shadow-purple-500/20',
  },
  indigo: {
    text: 'text-indigo-400',
    dot: 'bg-indigo-500',
    glow: 'shadow-indigo-500/20',
  },
  rose: {
    text: 'text-rose-400',
    dot: 'bg-rose-500',
    glow: 'shadow-rose-500/20',
  },
};

const theme = variantConfig[variant];
---

<div
  class:list={[
    'inline-flex select-none items-center justify-between gap-x-3 rounded-small px-3 py-1.5 transition-colors duration-300',
    'border',
    surfaceConfig[surface],
    'shadow-sm',
    className,
  ]}
>
  <div class="flex items-center gap-x-2.5">
    <Icon
      class="h-4 w-4 text-text-secondary/80"
      strokeWidth={1.5}
    />
    <div class="flex gap-1.5 font-sans text-xs uppercase tracking-wider">
      <span class="text-text-secondary/80 font-bold">{label}</span>
      <span class="bg-border/50 h-3 w-[1px] self-center"></span>
      <span class="font-medium text-text-primary">{value}</span>
    </div>
  </div>

  <div class="relative ml-2 flex h-2 w-2 items-center justify-center">
    <!-- Halo Permanente (Sutil volumen base) -->
    <span
      class:list={[
        'absolute h-3.5 w-3.5 rounded-full opacity-40 blur-[3px]',
        theme.dot,
      ]}></span>

    <!-- Animación Ring (Expansión sofisticada tipo radar con curva de Bézier) -->
    <span
      class:list={[
        'absolute h-2.5 w-2.5 rounded-full status-ring',
        theme.dot,
      ]}></span>

    <!-- Punto Base (Respiración elegante en el núcleo) -->
    <span class:list={['absolute h-1.5 w-1.5 rounded-full status-core shadow-sm', theme.dot]}></span>
  </div>
</div>

<style>
  /* Animación sofisticada: Respiración sutil en el núcleo */
  .status-core {
    animation: corePulse 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  /* Expansión tipo "Radar" o latido de alta precisión */
  .status-ring {
    animation: ringPulse 1.8s cubic-bezier(0.165, 0.84, 0.44, 1) infinite;
  }

  @keyframes corePulse {
    0%, 100% { 
      transform: scale(0.95); 
      opacity: 0.8; 
    }
    50% { 
      transform: scale(1.1); 
      opacity: 1; 
    }
  }

  @keyframes ringPulse {
    0% { 
      transform: scale(0.5); 
      opacity: 0.8; 
    }
    100% { 
      transform: scale(3.5); 
      opacity: 0; 
    }
  }
</style>
